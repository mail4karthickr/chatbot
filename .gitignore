# Environment / secrets — never commit these
**/.env
**/.env.local
**/.env.*.local

# Claude Code — per-user permission allowlists (may contain literal secrets)
**/.claude/settings.local.json

# Python
__pycache__/
*.pyc
.venv/

# Node / frontend
node_modules/
dist/
dist-ssr/
*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# OS / editor
.DS_Store
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
