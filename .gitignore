# Environment / secrets — never commit these
**/.env
**/.env.local
**/.env.*.local

# Chat session exports embed S3 presigned URLs (which contain the AWS Access
# Key ID) and inline PII from the corpus; never commit these
chat-session-*.html
**/chat-session-*.html

# Local parsing/eval scratch area — real insurance PDFs (PII) and parse dumps
parsing_test_files/

# Claude Code — per-user permission allowlists (may contain literal secrets)
**/.claude/settings.local.json

# Python
__pycache__/
*.pyc
.venv/

# Node / frontend
node_modules/
dist/
dist-ssr/
*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# OS / editor
.DS_Store
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
